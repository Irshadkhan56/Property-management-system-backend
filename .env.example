# Server Configuration
# PORT=5000
# NODE_ENV=development
# CORS_ORIGIN=http://localhost:5173

# Database Connection (Local or MongoDB Atlas)
# MONGO_URI=mongodb://127.0.0.1:27017/propdealer

# JWT Token Configurations
# JWT_SECRET=your_jwt_secret_here
# JWT_EXPIRES_IN=7d
# JWT_COOKIE_EXPIRES_IN=7

# Initial Default Administrator Credentials (Optional)
# DEFAULT_ADMIN_NAME="Default Admin"
# DEFAULT_ADMIN_EMAIL=admin@propertydealer.com
# DEFAULT_ADMIN_PASSWORD=admin123456

# Cloudinary Assets Hosting Configurations (Optional - Fallback to Local Disk Storage if missing)
# CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret
